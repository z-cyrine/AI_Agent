# LLM Configuration - Llama 3.3 70B via API Groq
LLM_PROVIDER=groq
LLM_API_KEY=api_key  # Clé API Groq (console.groq.com)
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# OpenSlice Configuration
OPENSLICE_BASE_URL=http://localhost:13082
OPENSLICE_USERNAME=
OPENSLICE_PASSWORD=

# Mode Mock : Simuler OpenSlice sans connexion réelle
# Mettre à "true" pour tester sans OpenSlice
OPENSLICE_MOCK_MODE=false

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Application Configuration
LOG_LEVEL=INFO
